# Скопируйте в .env (`cp .env.example .env`) и заполните DEEPSEEK_API_KEY.
# .env читают и docker compose, и Makefile (для go run).
# Правило: значения без пробелов, # и $ — иначе сломается парсинг Makefile.

# Backend
PORT=8090
DATABASE_URL=postgres://app:app@localhost:5432/getyouroffer?sslmode=disable
DEEPSEEK_API_KEY=sk-REPLACE_ME
# Опционально: другой OpenAI-совместимый эндпоинт (прокси или мок в тестах).
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Секрет для подписи JWT (HS256). Нужен для роутов /api/users/* — без него они
# отключены. Задайте длинное случайное значение: `openssl rand -hex 32`.
JWT_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# Postgres (docker-compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=getyouroffer
POSTGRES_PORT=5432
